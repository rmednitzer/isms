{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "manifest.schema.json",
  "title": "Evidence manifest",
  "type": "object",
  "required": [
    "schema_version",
    "period",
    "period_start",
    "period_end",
    "entries"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "period": {
      "enum": [
        "daily",
        "weekly",
        "monthly"
      ]
    },
    "period_start": {
      "type": "string",
      "format": "date"
    },
    "period_end": {
      "type": "string",
      "format": "date"
    },
    "previous_manifest": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "required": [
            "path",
            "sha256"
          ],
          "properties": {
            "path": {
              "type": "string"
            },
            "sha256": {
              "type": "string"
            }
          }
        }
      ]
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "sha256",
          "control_id"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "control_id": {
            "type": "string"
          },
          "collected_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "manifest_signed_at": {
      "type": "string",
      "format": "date-time"
    },
    "manifest_signed_by": {
      "type": "string"
    }
  }
}