{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "impact-assessment.schema.json",
  "title": "Law change impact assessment",
  "type": "object",
  "required": [
    "ia_id",
    "delta_id",
    "opened_at",
    "status"
  ],
  "properties": {
    "ia_id": {
      "type": "string",
      "pattern": "^IA-\\d{4}-\\d{3}$"
    },
    "delta_id": {
      "type": "string"
    },
    "opened_at": {
      "type": "string",
      "format": "date-time"
    },
    "opened_by": {
      "type": "string"
    },
    "status": {
      "enum": [
        "draft",
        "under_review",
        "approved",
        "rejected"
      ]
    },
    "affected_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "action_plan": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "approved_by": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string"
        }
      ]
    },
    "approved_at": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "format": "date-time"
        }
      ]
    }
  }
}