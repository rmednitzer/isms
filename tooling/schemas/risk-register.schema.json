{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "risk-register.schema.json",
  "title": "Risk register",
  "type": "object",
  "required": [
    "schema_version",
    "methodology_ref",
    "risks"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "methodology_ref": {
      "type": "string"
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^RSK-\\d{4}$"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "asset_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "threat": {
            "type": "string"
          },
          "vulnerability": {
            "type": "string"
          },
          "likelihood": {
            "enum": [
              "rare",
              "unlikely",
              "possible",
              "likely",
              "certain"
            ]
          },
          "impact": {
            "enum": [
              "negligible",
              "minor",
              "moderate",
              "major",
              "severe"
            ]
          },
          "inherent_rating": {
            "type": "string"
          },
          "residual_rating": {
            "type": "string"
          },
          "treatment": {
            "enum": [
              "accept",
              "mitigate",
              "transfer",
              "avoid"
            ]
          },
          "control_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "owner": {
            "type": "string",
            "pattern": "^role:"
          },
          "review_date": {
            "type": "string",
            "format": "date"
          },
          "status": {
            "enum": [
              "identified",
              "assessed",
              "treating",
              "treated",
              "accepted",
              "closed"
            ]
          }
        }
      }
    }
  }
}