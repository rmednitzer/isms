{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "asset-register.schema.json",
  "title": "Asset register",
  "type": "object",
  "required": ["schema_version", "assets"],
  "properties": {
    "schema_version": { "const": 1 },
    "description": { "type": "string" },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "class", "owner_role", "in_scope", "lifecycle_status"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^ASSET-\\d{4}$"
          },
          "name": { "type": "string", "minLength": 1 },
          "class": {
            "enum": [
              "information",
              "software",
              "hardware",
              "service",
              "facility",
              "personnel",
              "supply"
            ]
          },
          "description": { "type": "string" },
          "owner_role": {
            "type": "string",
            "pattern": "^role:[A-Za-z0-9_-]+$"
          },
          "custodian_role": {
            "oneOf": [
              { "type": "null" },
              { "type": "string", "pattern": "^role:[A-Za-z0-9_-]+$" }
            ]
          },
          "criticality": {
            "enum": ["low", "medium", "high", "critical"]
          },
          "classification": {
            "enum": ["public", "internal", "confidential", "restricted"]
          },
          "location_ref": {
            "oneOf": [
              { "type": "null" },
              { "type": "string", "pattern": "^FAC-\\d{3}$" }
            ]
          },
          "zone_ref": {
            "oneOf": [
              { "type": "null" },
              { "type": "string", "pattern": "^ZONE-\\d{3}$" }
            ]
          },
          "network_ref": {
            "oneOf": [
              { "type": "null" },
              { "type": "string", "pattern": "^NET-\\d{3}$" }
            ]
          },
          "supplier_refs": {
            "type": "array",
            "items": { "type": "string", "pattern": "^SUP-\\d{3}$" }
          },
          "data_refs": {
            "type": "array",
            "items": { "type": "string", "pattern": "^DATA-\\d{3}$" }
          },
          "dependencies": {
            "type": "array",
            "items": { "type": "string", "pattern": "^ASSET-\\d{4}$" }
          },
          "in_scope": { "type": "boolean" },
          "lifecycle_status": {
            "enum": ["planned", "operational", "legacy", "retired"]
          },
          "operational_ref": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
